# ===========================================
# SECURE API CONFIGURATION
# ===========================================
# IMPORTANT: This file contains sensitive API keys
# NEVER commit this file to version control!
# 
# These keys are stored server-side only and are
# NEVER sent to the browser - hackers cannot steal
# them using browser dev tools.
# ===========================================

# Google API Key (for Gemini LLM - chat/vision)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Google Gemini Model (optional, defaults to gemini-3.1-flash-lite-preview)
GOOGLE_MODEL=gemini-3.1-flash-lite-preview

# OpenAI API Key (for TTS and STT only)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI TTS Model (optional, defaults to tts-1)
# Options: tts-1, tts-1-hd
OPENAI_TTS_MODEL=tts-1

# OpenAI TTS Voice (optional, defaults to fable)
# Options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=fable

# OpenAI STT Model (optional, defaults to whisper-1)
OPENAI_STT_MODEL=whisper-1

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Allowed origins in production (comma-separated)
# Leave empty or commented out for development
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
